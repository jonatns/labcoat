---
import brand from '../../../../brand.json';

const notice = brand.docsChannelNotice.replace(
  '`labcoat docs --llm`',
  '<code>labcoat docs --llm</code>',
);
---

<div class="sl-banner" data-pagefind-ignore>
  <span set:html={notice} />
  <a href="/docs/reference/stability/">Release details</a>
</div>

<style>
  @layer starlight.core {
    .sl-banner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      background: oklch(91% 0.215 125);
      color: oklch(14% 0.03 140);
      font-size: 0.8rem;
      font-weight: 520;
      line-height: 1.45;
      text-align: center;
      text-wrap: balance;
      box-shadow: var(--sl-shadow-sm);
    }

    .sl-banner a { color: inherit; font-weight: 650; white-space: nowrap; }
    .sl-banner :global(code) { padding: 0.08rem 0.3rem; background: color-mix(in oklch, currentColor, transparent 84%); color: inherit; }

    @media (max-width: 50rem) {
      .sl-banner { align-items: flex-start; flex-direction: column; gap: 0.25rem; text-align: left; }
    }
  }
</style>
