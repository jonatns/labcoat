---
import Icon from './Icon.astro';

interface Props {
  command: string;
  label?: string;
}

const { command, label = 'Copy command' } = Astro.props;
---

<div class="copy-command">
  <span class="prompt" aria-hidden="true">$</span>
  <code>{command}</code>
  <button type="button" data-copy={command} aria-label={label}>
    <Icon name="copy" />
    <span data-copy-label>Copy</span>
  </button>
</div>
