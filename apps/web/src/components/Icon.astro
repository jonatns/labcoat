---
type IconName = 'scaffold' | 'test' | 'devnet' | 'deploy' | 'trace' | 'copy' | 'external' | 'check' | 'warning' | 'status';

interface Props {
  name: IconName;
  label?: string;
  size?: number;
  class?: string;
}

const { name, label, size = 24, class: className = '' } = Astro.props;
---

<svg
  class:list={['labcoat-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
>
  {name === 'scaffold' && <><path d="M4 8h16M8 4v16M4 16h16M16 4v16"></path><path d="m11 11 2 2m0-2-2 2"></path></>}
  {name === 'test' && <><path d="M9 3h6M10 3v5l-5 9a2.5 2.5 0 0 0 2.2 4h9.6A2.5 2.5 0 0 0 19 17l-5-9V3"></path><path d="m8.5 16 2 2 5-5"></path></>}
  {name === 'devnet' && <><rect x="3" y="4" width="18" height="5" rx="1"></rect><rect x="3" y="15" width="18" height="5" rx="1"></rect><path d="M7 9v6m10-6v6"></path><circle cx="7" cy="6.5" r=".5" fill="currentColor" stroke="none"></circle><circle cx="7" cy="17.5" r=".5" fill="currentColor" stroke="none"></circle></>}
  {name === 'deploy' && <><path d="M12 21V7m0 0L7 12m5-5 5 5"></path><path d="M4 16v4h16v-4"></path></>}
  {name === 'trace' && <><path d="M3 15h4l2-7 4 11 2-7h6"></path><path d="M3 5h18"></path></>}
  {name === 'copy' && <><rect x="8" y="8" width="11" height="11" rx="2"></rect><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"></path></>}
  {name === 'external' && <><path d="M14 5h5v5M19 5l-8 8"></path><path d="M17 13v6H5V7h6"></path></>}
  {name === 'check' && <path d="m5 12 4 4L19 6"></path>}
  {name === 'warning' && <><path d="M12 3 2.8 20h18.4L12 3Z"></path><path d="M12 9v5m0 3h.01"></path></>}
  {name === 'status' && <><circle cx="12" cy="12" r="8"></circle><circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"></circle></>}
</svg>
