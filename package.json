{
  "name": "labcoat-monorepo",
  "private": true,
  "description": "Labcoat: smart contract development toolkit for Alkanes on Bitcoin. Isomer: the desktop devnet inside it.",
  "license": "MIT",
  "author": "Jonathan P. Navarrete <jonatns@gmail.com>",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @labcoat/web dev",
    "build:web": "pnpm --filter @labcoat/web build",
    "check:web": "pnpm --filter @labcoat/web check",
    "sync:web-reference": "pnpm --filter @labcoat/web sync:reference",
    "dev:isomer": "pnpm --filter @isomer/desktop tauri dev",
    "build:isomer": "pnpm --filter @isomer/desktop tauri build"
  }
}
