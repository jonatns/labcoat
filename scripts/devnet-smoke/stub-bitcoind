#!/usr/bin/env python3
"""Protocol stub of bitcoind for devnet smoke tests.

Implements just enough of the JSON-RPC surface that isomer-core's wallet
bootstrap, status enrichment, faucet, and mining paths exercise their real
code. Used where the real Bitcoin Core binary cannot be downloaded
(sandboxed CI); NOT a substitute for integration tests against real nodes.
"""
import hashlib
import json
import re
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

# isomer-core probes binaries with `--version` and waits for exit
if "--version" in sys.argv:
    print("Bitcoin Core version v0.0.0-stub")
    sys.exit(0)

PORT = 18443
for arg in sys.argv[1:]:
    m = re.match(r"-rpcport=(\d+)", arg)
    if m:
        PORT = int(m.group(1))

STATE = {"height": 0, "wallets": []}


def fake_hash(seed: str) -> str:
    return hashlib.sha256(seed.encode()).hexdigest()


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        print("[stub-bitcoind]", fmt % args, flush=True)

    def do_GET(self):
        self.send_response(404)
        self.end_headers()

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        try:
            req = json.loads(self.rfile.read(length) or b"{}")
        except json.JSONDecodeError:
            req = {}
        method = req.get("method", "")
        params = req.get("params", [])
        result, error = None, None

        if method == "listwallets":
            result = STATE["wallets"]
        elif method == "createwallet":
            name = params[0] if params else "dev"
            if name in STATE["wallets"]:
                error = {"code": -4, "message": "Wallet already exists"}
            else:
                STATE["wallets"].append(name)
                result = {"name": name}
        elif method == "loadwallet":
            result = {"name": params[0] if params else "dev"}
        elif method == "getnewaddress":
            result = "bcrt1qstub0address0for0smoke0tests0only000"
        elif method == "getblockcount":
            result = STATE["height"]
        elif method == "generatetoaddress":
            count = int(params[0]) if params else 1
            hashes = []
            for i in range(count):
                STATE["height"] += 1
                hashes.append(fake_hash(f"block-{STATE['height']}"))
            result = hashes
        elif method == "getmempoolinfo":
            result = {"size": 0}
        elif method == "sendtoaddress":
            result = fake_hash(f"tx-{params}")
        elif method == "getblockhash":
            result = fake_hash(f"block-{params[0] if params else 0}")
        elif method == "getblock":
            result = {"time": 1752400000, "tx": [fake_hash("coinbase")]}
        else:
            error = {"code": -32601, "message": f"Method not found: {method}"}

        body = json.dumps(
            {"jsonrpc": "1.0", "id": req.get("id"), "result": result, "error": error}
        ).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


if __name__ == "__main__":
    print(f"[stub-bitcoind] listening on {PORT}", flush=True)
    ThreadingHTTPServer(("127.0.0.1", PORT), Handler).serve_forever()
